# ═════════════════════════════════════════════════════════════════════════════════
# ZM COPILOT — ENVIRONMENT CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# DO NOT commit .env to git — secrets should never be in version control!

# ─────────────────────────────────────────────────────────────────────────────────
# AWS BEDROCK CREDENTIALS (REQUIRED for AI diagnosis engine)
# ─────────────────────────────────────────────────────────────────────────────────
# Get these from your AWS Account → IAM → Users → Security Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-south-1

# Optional: Bedrock Model Configuration (defaults shown below)
BEDROCK_MODEL_ID_PRIMARY=arn:aws:bedrock:ap-south-1:YOUR_ACCOUNT_ID:inference-profile/your-profile
BEDROCK_MODEL_ID_FALLBACK=anthropic.claude-3-5-sonnet-20240620-v1:0

# ─────────────────────────────────────────────────────────────────────────────────
# LOGGING CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT QUICK START
# ─────────────────────────────────────────────────────────────────────────────────
# 1. Fill in AWS credentials above
# 2. Save this file as .env in project root
# 3. Run: pip install -r requirements.txt
# 4. Run: streamlit run app.py
# 5. Open: http://localhost:8501
